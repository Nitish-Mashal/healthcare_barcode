  "html": "<style>\r\n.print-format table, .print-format tr, \r\n.print-format td, .print-format div, .print-format p {\r\n\tfont-family: Monospace;\r\n\tline-height: 170%;\r\n\tvertical-align: middle;\r\n}\r\n\r\n@media screen {\r\n\t.print-format {\r\n\t\twidth: 6in;\r\n\t\tpadding: 0.25in;\r\n\t\tmin-height: 2in;\r\n\t}\r\n}\r\n</style>\r\n\r\n{% set column = 0 %}\r\n\r\n<table>\r\n\r\n{% for _ in range(0, doc.num_print) %}\r\n\r\n{% if column == 0 %}<tr>{% endif %}\r\n\r\n<td style=\"width:2in; height:1.8in; text-align:center\">\r\n\r\n<strong>{{ doc.name }}</strong><br>\r\n\r\n<div class=\"barcode\">\r\n{% if doc.custom_barcode_html %}\r\n<img src=\"data:image/png;base64,{{ doc.custom_barcode_html }}\" style=\"width:200px;\">\r\n{% endif %}\r\n</div>\r\n\r\n<br>\r\n\r\n{{ doc.patient_name }}<br>\r\n{{ doc.sample }}\r\n\r\n</td>\r\n\r\n{% if column == 0 %}\r\n{% set column = column + 1 %}\r\n\r\n{% elif column == 2 %}\r\n</tr>\r\n{% set column = 0 %}\r\n\r\n{% else %}\r\n{% set column = column + 1 %}\r\n{% endif %}\r\n\r\n{% endfor %}\r\n\r\n</table>",
